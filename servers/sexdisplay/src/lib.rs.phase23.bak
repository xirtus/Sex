pub const PDX_ALLOCATE_MEMORY: u64 = 31;
pub const PDX_MAP_MEMORY: u64 = 30;

// New syscalls for basic window manipulation
pub const PDX_MOVE_WINDOW: u64 = 0xEE; // Re-indexed
pub const PDX_RESIZE_WINDOW: u64 = 0xEF; // Re-indexed

// New syscall for committing individual window frames
pub const PDX_WINDOW_COMMIT_FRAME: u64 = 0xF0;


