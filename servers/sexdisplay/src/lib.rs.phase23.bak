#![no_std]
#![no_main]
#![allow(unreachable_patterns)]
#![allow(unused_variables)]
#![allow(non_snake_case)]

extern crate alloc;
use alloc::vec::Vec;
use core::fmt::Write;

#[macro_export]
macro_rules! serial_println {
    ($($arg:tt)*) => {
        let mut buf = [0u8; 256];
        let mut writer = $crate::Wrapper::new(&mut buf);
        let _ = core::fmt::write(&mut writer, format_args!($($arg)*));
        let _ = writer.write_str("\n");
        let len = writer.pos;
        unsafe {
            core::arch::asm!("syscall",
                in("rax") 69,
                in("rdi") buf.as_ptr(),
                in("rsi") len,
            );
        }
    };
}

pub struct Wrapper<'a> {
    pub buf: &'a mut [u8],
    pub pos: usize,
}
impl<'a> Wrapper<'a> {
    pub fn new(buf: &'a mut [u8]) -> Self { Self { buf, pos: 0 } }
}
impl<'a> core::fmt::Write for Wrapper<'a> {
    fn write_str(&mut self, s: &str) -> core::fmt::Result {
        let bytes = s.as_bytes();
        let remaining = self.buf.len() - self.pos;
        let to_copy = if bytes.len() > remaining { remaining } else { bytes.len() };
        self.buf[self.pos..self.pos+to_copy].copy_from_slice(&bytes[..to_copy]);
        self.pos += to_copy;
        Ok(())
    }
}

// Define TagMask for clarity
pub type TagMask = u64;

// Represents the state of a single output (monitor)
#[derive(Debug, Clone, Copy)]
pub struct OutputState {
    pub id: u64,
    pub width: u32,
    pub height: u32,
    pub x: u32, // Position in global coordinate space
    pub y: u32,
}

// Represents various rendering flags for aesthetics
#[derive(Clone, Copy, Debug, PartialEq, Default)]
pub struct RenderState {
    pub blur_strength: u32,
    pub corner_radius: u32,
    pub alpha: u8, // 0-255
    pub animation_curve: u8, // e.g., 0 for linear, 1 for ease-out
}

// Ephemeral snapshot of the UI state for rendering decisions.
// Never stored, always rebuilt.
#[derive(Clone, Copy)]
pub struct UiStateGraph<'a> {
    pub windows: &'a [Window], // Borrowed slice of all windows
    pub outputs: &'a [OutputState], // Borrowed slice of output states
    pub active_tags: TagMask, // The currently active tag mask (view)
    pub focus_id: Option<u64>, // ID of the currently focused window
    pub render_flags: RenderState,      // blur/radius/alpha/animation_curve (compositor only)
}


// Enum for window states (e.g., normal, tiled, floating, minimized)
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum WindowState {
    Normal,
    Tiled,
    Floating,
    Minimized,
    Maximized,
    Fullscreen,
}

// Represents a single managed window.
// Using Copy for simplicity in no_std, might need RefCell/Rc later if complex.
#[repr(C)]
#[derive(Debug, Clone, Copy)]
pub struct Window {
    pub id: u64,
    pub x: u32,
    pub y: u32,
    pub width: u32,
    pub height: u32,
    pub pfn_base: u64, // Base PFN for the window's buffer
    pub state: WindowState,
    pub pd_id: u32, // Protection Domain ID of the owning process
    // New fields for UI aesthetics
    pub corner_radius: u32,
    pub blur_strength: u32,
    pub is_animating: bool,
    pub border_color: u32,
    pub border_thickness: u32,
    pub tag_mask: u64, // New field for River-like tags
    pub render_state: RenderState, // Individual window render state
    pub workspace_mask: u32, // New field for workspace association

    // Animation target fields
    pub target_x: u32,// Enum for different tiling layouts
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum TilingLayout {
    MasterStack,    // Default layout with master and stack areas
    VerticalStack,  // All windows stacked vertically
    HorizontalStack, // All windows stacked horizontally
    Floating,       // Windows retain their position and size
    // Add more layouts as needed
}

// Represents the tiling layout configuration.
#[derive(Debug, Clone, Copy)]
pub struct TilingState {
    pub master_count: usize, // Number of windows in the master area
    pub master_ratio: f32,   // Ratio of master area width to screen width (e.g., 0.5 for 50%)
    pub gaps: u32,           // Gap size between windows and screen edges
    pub current_layout: TilingLayout, // The currently active tiling layout
    // Could add more tiling strategies later
}

// Placeholder for LayeringState - now global, not per workspace
#[derive(Debug, Clone, Copy)]
pub struct LayeringState {
    // Z-order management logic
    pub z_order: [u64; MAX_WINDOWS], // Ordered list of window IDs by Z-index
    pub num_layers: usize,
}

const MAX_WINDOWS: usize = 64;
const MAX_VIEWS: usize = 4; // Define maximum number of views/workspaces

// This constant is no longer relevant as windows are globally managed with tags.

pub const SEX_COMPOSITOR_MAGIC: u32 = 0x53455843; // 'SEXC'
pub const PDX_COMPOSITOR_COMMIT: u64 = 0xDD;
pub const PDX_SEX_WINDOW_CREATE: u64 = 0xDE; // Matches silk-shell's definition
pub const PDX_SET_WINDOW_DECORATIONS: u64 = 0xE2;
pub const PDX_GET_DISPLAY_INFO: u64 = 0xE3;

// New syscalls for basic window management
pub const PDX_FOCUS_WINDOW: u64 = 0xE4;
pub const PDX_MINIMIZE_WINDOW: u64 = 0xE5;
pub const PDX_MAXIMIZE_WINDOW: u64 = 0xE6;
pub const PDX_CLOSE_WINDOW: u64 = 0xE7;

// New syscalls for Tag management
pub const PDX_SET_WINDOW_TAGS: u64 = 0xE8;
pub const PDX_GET_WINDOW_TAGS: u64 = 0xE9;
pub const PDX_SET_VIEW_TAGS: u64 = 0xEA;
pub const PDX_GET_VIEW_TAGS: u64 = 0xEB;
pub const PDX_SWITCH_VIEW: u64 = 0xF4; // New syscall for switching views
pub const PDX_GET_ALL_VIEWS: u64 = 0xF5; // New syscall to get all views
pub const PDX_REGISTER_HOTKEY: u64 = 0xF6; // New syscall to register a global hotkey
pub const PDX_SEND_NOTIFICATION: u64 = 0xF7; // New syscall to send a system-wide notification
pub const PDX_SHOW_LOGIN_SCREEN: u64 = 0xF8; // New syscall to display login screen
pub const PDX_HIDE_LOGIN_SCREEN: u64 = 0xF9; // New syscall to hide login screen
pub const PDX_SWITCH_USER_SESSION: u64 = 0xFA; // New syscall to switch user session
pub const PDX_GET_UI_TREE: u64 = 0xFB; // New syscall to get UI tree for accessibility

// System telemetry (must match sex-pdx constants 0xFC-0xFE)
pub const PDX_GET_TIME: u64 = 0xFC;       // → (seconds << 20) | millis
pub const PDX_GET_CPU_USAGE: u64 = 0xFD;  // arg0=core_id → percent*100
pub const PDX_GET_MEM_USAGE: u64 = 0xFE;  // → (used_kb << 32) | total_kb

// New syscalls for UI aesthetics
pub const PDX_SET_WINDOW_ROUNDNESS: u64 = 0xF1;
pub const PDX_SET_WINDOW_BLUR: u64 = 0xF2;
pub const PDX_SET_WINDOW_ANIMATION: u64 = 0xF3;

