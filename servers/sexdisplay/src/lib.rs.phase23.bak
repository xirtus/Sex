#[derive(Debug, Clone)]
pub struct Notification {
    pub id: u64,
    pub title: Vec<u8>,
    pub message: Vec<u8>,
    pub icon_pfn: u64,
    pub start_time_ms: u64,
    pub display_duration_ms: u64,
}

// Intermediate data structures required by the projection functions.
// Rect is already defined in sex-pdx so it should be imported instead of redefined.
pub struct LayoutResult {
    pub window_layouts: Vec<(u64, Rect)>, // (window_id, x, y, width, height)
    // Other layout-specific data
}

// Represents the result of animation application
pub struct AnimatedLayout {
    pub window_layouts: Vec<(u64, Rect)>, // Animated (window_id, x, y, width, height)
    // Animation-specific data
}

// Represents drawing commands for the renderer
pub struct RenderCommands {
    pub commands: Vec<RenderCommand>, // List of individual drawing commands
}

// Individual rendering command (e.g., DrawRect, DrawWindowBuffer)
pub enum RenderCommand {
    Clear(u32), // Clear color
    DrawRect(Rect, u32), // Rectangle with color
    DrawWindow(u64, Rect, u64, RenderState), // (window_id, target_rect, pfn_base, RenderState)
    DrawBitmap(Rect, Vec<u8>, u32, u32, u32), // (target_rect, bitmap_1bit_alpha_data, bitmap_width, bitmap_height, color)
    // ... other commands for text, blur, rounded corners
}

pub struct PFNList(pub Vec<u64>); // Wrapper for Vec<u64> for clarity

// Projection Function 1: Filters windows by active tags
fn visible_windows<'a>(graph: &'a UiStateGraph<'a>) -> impl Iterator<Item = &'a Window> {
    graph.windows.iter()
        .filter(move |w| (w.tag_mask & graph.active_tags) != 0)
}

// Projection Function 2: Computes layout for visible windows
// For simplicity, re-implementing basic tiling here, adapted from old Workspace::apply_tiling
fn compute_layout(visible: &[&Window], output: &OutputState, tiling_state: &TilingState) -> LayoutResult {
    let mut window_layouts = Vec::new();
    let fb_width = output.width;
    let fb_height = output.height;
    let gaps = tiling_state.gaps;

    let num_visible = visible.len();
    if num_visible == 0 { return LayoutResult { window_layouts }; }

    match tiling_state.current_layout {
        TilingLayout::MasterStack => {
            let master_count = tiling_state.master_count;
            let master_ratio = tiling_state.master_ratio;

            let master_area_width = (fb_width as f32 * master_ratio) as u32;
            let tiled_area_x = gaps;
            let tiled_area_y = gaps;
            let tiled_area_width = fb_width - gaps * 2;
            let tiled_area_height = fb_height - gaps * 2;

            let num_master_windows = num_visible.min(master_count);
            let num_stack_windows = num_visible.saturating_sub(num_master_windows);

            let master_width = if num_stack_windows > 0 { master_area_width } else { tiled_area_width };
            let stack_width = tiled_area_width - master_width - if num_master_windows > 0 && num_stack_windows > 0 { gaps } else { 0 };

            let master_window_height = if num_master_windows > 0 { (tiled_area_height - gaps * (num_master_windows as u32 - 1)) / num_master_windows as u32 } else { 0 };
            let mut current_y = tiled_area_y;
            for i in 0..num_master_windows {
                let window_ref = visible[i];
                window_layouts.push((window_ref.id, Rect { x: tiled_area_x as i32, y: current_y as i32, w: master_width, h: master_window_height }));
                current_y += master_window_height + gaps;
            }

            let stack_window_height = if num_stack_windows > 0 { (tiled_area_height - gaps * (num_stack_windows as u32 - 1)) / num_stack_windows as u32 } else { 0 };
            let mut current_y = tiled_area_y;
            for i in 0..num_stack_windows {
                let window_ref = visible[num_master_windows + i];
                window_layouts.push((window_ref.id, Rect { x: (tiled_area_x + master_width + gaps) as i32, y: current_y as i32, w: stack_width, h: stack_window_height }));
                current_y += stack_window_height + gaps;
            }
        },
        TilingLayout::VerticalStack => {
            let tiled_area_x = gaps;
            let tiled_area_y = gaps;
            let tiled_area_width = fb_width - gaps * 2;
            let tiled_area_height = fb_height - gaps * 2;

            let window_height = (tiled_area_height - gaps * (num_visible as u32 - 1)) / num_visible as u32;
            let mut current_y = tiled_area_y;
            for i in 0..num_visible {
                let window_ref = visible[i];
                window_layouts.push((window_ref.id, Rect { x: tiled_area_x as i32, y: current_y as i32, w: tiled_area_width, h: window_height }));
                current_y += window_height + gaps;
            }
        },
        TilingLayout::HorizontalStack => {
            let tiled_area_x = gaps;
            let tiled_area_y = gaps;
            let tiled_area_width = fb_width - gaps * 2;
            let tiled_area_height = fb_height - gaps * 2;

            let window_width = (tiled_area_width - gaps * (num_visible as u32 - 1)) / num_visible as u32;
            let mut current_x = tiled_area_x;
            for i in 0..num_visible {
                let window_ref = visible[i];
                window_layouts.push((window_ref.id, Rect { x: current_x as i32, y: tiled_area_y as i32, w: window_width, h: tiled_area_height }));
                current_x += window_width + gaps;
            }
        },
        _ => { /* Floating or other layouts */ }
    }
    LayoutResult { window_layouts }
}



// Projection Function 4: Translates layout to raw drawing commands
// This is where blur, rounded corners would be handled by rendering directly
fn render_decisions(animated: &AnimatedLayout, output: &OutputState, all_windows_map: &[(u64, &Window)]) -> RenderCommands {
    let mut commands = Vec::new();
    // Silk DE brand background — deep navy
    commands.push(RenderCommand::Clear(0xFF1a1a2e));

    // Silk Bar — 28px strip at screen bottom
    commands.push(RenderCommand::DrawRect(
        Rect { x: 0, y: (output.height as i32) - 28, w: output.width, h: 28 },
        0xFF2d2d54,
    ));
    // Silk Bar accent line
    commands.push(RenderCommand::DrawRect(
        Rect { x: 0, y: (output.height as i32) - 29, w: output.width, h: 1 },
        0xFF5555aa,
    ));

    for (window_id, rect) in &animated.window_layouts {
        // Fetch original window properties for aesthetics
        if let Some((_, original_window)) = all_windows_map.iter().find(|(id, _)| *id == *window_id) {
            commands.push(RenderCommand::DrawWindow(*window_id, *rect, original_window.pfn_base, original_window.render_state)); // Pass render state

            // Draw border if present
            if original_window.border_thickness > 0 {
                let bt = original_window.border_thickness as i32;
                let bc = original_window.border_color;
                
                // Top border
                commands.push(RenderCommand::DrawRect(Rect { x: rect.x - bt, y: rect.y - bt, w: (rect.w as i32 + 2 * bt) as u32, h: bt as u32 }, bc));
                // Bottom border
                commands.push(RenderCommand::DrawRect(Rect { x: rect.x - bt, y: rect.y + rect.h as i32, w: (rect.w as i32 + 2 * bt) as u32, h: bt as u32 }, bc));
                // Left border
                commands.push(RenderCommand::DrawRect(Rect { x: rect.x - bt, y: rect.y, w: bt as u32, h: rect.h }, bc));
                // Right border
                commands.push(RenderCommand::DrawRect(Rect { x: rect.x + rect.w as i32, y: rect.y, w: bt as u32, h: rect.h }, bc));
            }
        } else {
            commands.push(RenderCommand::DrawWindow(*window_id, *rect, 0, RenderState::default())); // Dummy with default render state
        }
    }
    RenderCommands { commands }
}

// Projection Function 5: Builds PFN list for zero-copy handoff
fn build_pfn_list(commands: RenderCommands) -> PFNList {
    let mut pfns = Vec::new();
    for command in commands.commands {
        if let RenderCommand::DrawWindow(_id, _rect, pfn_base, _render_state) = command {
            if pfn_base != 0 {
                pfns.push(pfn_base);
            }
        }
    }
    PFNList(pfns)
}

// Projection Function 6: Commits the PFN list to scanout
fn commit_to_scanout(pfns: PFNList) {
    // This function will likely be a wrapper around a direct kernel syscall
    // to program the display controller with the list of PFNs for scanout.
    // For now, it's a placeholder.
    let _ = pfns; // Suppress unused warning
}

use sex_pdx::{pdx_allocate_memory, pdx_map_memory, Rect}; // Rect imported here
use sex_graphics::WindowBuffer;

#[no_mangle]
pub unsafe extern "C" fn memcpy(dest: *mut u8, src: *const u8, n: usize) -> *mut u8 {
    let mut i = 0;
    while i < n {
        *dest.add(i) = *src.add(i);
        i += 1;
    }
    dest
}

#[no_mangle]
pub unsafe extern "C" fn memset(s: *mut u8, c: i32, n: usize) -> *mut u8 {
    let mut i = 0;
    while i < n {
        *s.add(i) = c as u8;
        i += 1;
    }
    s
}

#[no_mangle]
pub unsafe extern "C" fn memcmp(s1: *const u8, s2: *const u8, n: usize) -> i32 {
    let mut i = 0;
    while i < n {
        let a = *s1.add(i);
        let b = *s2.add(i);
        if a != b {
            return a as i32 - b as i32;
        }
        i += 1;
    }
    0
}

pub struct SexCompositor {
    pub magic: u32,
    pub global_fb_width: u32,  // Total virtual desktop width
    pub global_fb_height: u32, // Total virtual desktop height

    // Multi-monitor support
    pub outputs: Vec<OutputState>, // Information about each connected display
    pub internal_framebuffers: Vec<WindowBuffer>, // One framebuffer per output
    pub internal_framebuffer_pfn_bases: Vec<u64>, // PFN base for each internal framebuffer

    pub current_scanout_pfn_base: u64, // Base PFN of the current scanout buffer (for compatibility, might be per-output later)

    // Global window and tag management
    pub all_windows: [Option<Window>; MAX_WINDOWS],
    pub current_tag_view_mask: u64, // The active tag mask for visibility filtering

    // Dynamic Workspace Management
    pub views: Vec<u64>,          // List of available view tag masks
    pub current_view_index: usize, // Index of the currently active view

    pub next_window_id: u64,
    pub next_notification_id: u64,
    pub global_z_order: LayeringState, // Global Z-order for all visible windows
    pub tiling_state: TilingState, // Global tiling state

    // Focus & Workspace Management
    pub focused_window_id: Option<u64>, // ID of the currently focused window
    pub active_workspace_mask: u32, // The currently active workspace tag mask

    // Focus & Workspace Management
    pub focused_window_id: Option<u64>, // ID of the currently focused window
    pub focused_window_id: Option<u64>, // ID of the currently focused window
    pub active_workspace_mask: u32, // The currently active workspace tag mask

    // Mouse cursor position
    pub cursor_x: u32,
    pub cursor_y: u32,    // Registered hotkeys for global shortcuts
    pub registered_hotkeys: Vec<Hotkey>,

    // Current keyboard modifiers state
    pub current_modifiers: u16,

    // Active notifications
    pub active_notifications: Vec<Notification>,

    // Session management state
    pub in_login_screen: bool,
    pub login_manager_pd_id: Option<u32>,
}

// Linux input event codes (subset for mouse)
pub const EV_SYN: u16 = 0x00;
pub const EV_KEY: u16 = 0x01;
pub const EV_REL: u16 = 0x02;
pub const EV_ABS: u16 = 0x03;

pub const REL_X: u16 = 0x00;
pub const REL_Y: u16 = 0x01;
pub const REL_WHEEL: u16 = 0x08;

pub const BTN_LEFT: u16 = 0x110;
pub const BTN_RIGHT: u16 = 0x111;
pub const BTN_MIDDLE: u16 = 0x112;

// Keyboard modifiers
pub const MOD_NONE: u16 = 0x0000;
pub const MOD_LSHIFT: u16 = 0x0001;
pub const MOD_RSHIFT: u16 = 0x0002;
pub const MOD_LCTRL: u16 = 0x0004;
pub const MOD_RCTRL: u16 = 0x0008;
pub const MOD_LALT: u16 = 0x0010;
pub const MOD_RALT: u16 = 0x0020;
pub const MOD_LSUPER: u16 = 0x0040;
pub const MOD_RSUPER: u16 = 0x0080;

impl SexCompositor {
    pub fn new(global_width: u32, global_height: u32, _stride: u32) -> Self { // _stride is now unused
        serial_println!("sexdisplay: Initializing compositor...");
        // Single output matching limine.cfg resolution (1280x720 @ 32bpp)
        let mut outputs = Vec::with_capacity(1);
        let mut internal_framebuffers = Vec::with_capacity(1);
        let mut internal_framebuffer_pfn_bases = Vec::with_capacity(1);

        // Output 0 — primary display
        let output0_width: u32 = 1280;
        let output0_height: u32 = 720;
        let output0_stride = output0_width;
        let output0_size = (output0_width * output0_height * 4) as u64;

        serial_println!("sexdisplay: Allocating FB0 ({} bytes)...", output0_size);
        let pfn0_base = match pdx_allocate_memory(PDX_ALLOCATE_MEMORY, output0_size) {
            Ok(pfn) => pfn,
            Err(_) => {
                serial_println!("sexdisplay: FB0 allocation FAILED");
                loop { /* Handle allocation error */ }
            }
        };
        serial_println!("sexdisplay: FB0 allocated at PFN {:#x}", pfn0_base);

        serial_println!("sexdisplay: Mapping FB0...");
        let virt_addr0 = match pdx_map_memory(PDX_MAP_MEMORY, pfn0_base, output0_size) {
            Ok(vaddr) => vaddr,
            Err(_) => {
                serial_println!("sexdisplay: FB0 mapping FAILED");
                loop { /* Handle mapping error */ }
            }
        };
        serial_println!("sexdisplay: FB0 mapped at {:#x}", virt_addr0);

        outputs.push(OutputState { id: 0, width: output0_width, height: output0_height, x: 0, y: 0 });
        internal_framebuffers.push(unsafe { WindowBuffer::new(virt_addr0, output0_width, output0_height, output0_stride) });
        internal_framebuffer_pfn_bases.push(pfn0_base);
        
        let mut views = Vec::with_capacity(MAX_VIEWS);
        for i in 0..MAX_VIEWS {
            views.push(1 << i); // Each view gets a unique tag
        }

        Self {
            magic: SEX_COMPOSITOR_MAGIC,
            global_fb_width: global_width,
            global_fb_height: global_height,

            outputs,
            internal_framebuffers,
            internal_framebuffer_pfn_bases,

            current_scanout_pfn_base: 0, // Initially no scanout (will be set per-output later)

            // Initialize global window and tag management fields
            all_windows: [None; MAX_WINDOWS],
            current_tag_view_mask: views[0], // Default to showing the first view's tag

            // Dynamic Workspace Management
            views,
            current_view_index: 0,

            next_window_id: 1,
            next_notification_id: 1,
            global_z_order: LayeringState {
                z_order: [0; MAX_WINDOWS],
                num_layers: 0,
            },
            tiling_state: TilingState {
                master_count: 1,
                master_ratio: 0.5,
                gaps: 4,
                current_layout: TilingLayout::MasterStack,
            },
            // Focus & Workspace Management
            focused_window_id: None, // Initialize focused_window_id
            active_workspace_mask: 1, // Initialize active_workspace_mask to default (1)

            cursor_x: global_width / 2, // Initialize cursor to center
            cursor_y: global_height / 2, // Initialize cursor to center

            registered_hotkeys: Vec::new(),
            current_modifiers: MOD_NONE,

            // Active notifications
            active_notifications: Vec::new(),

            // Session management state
            in_login_screen: false,
            login_manager_pd_id: None,
        }
    }

    /// Helper to find a window in the global list by ID, returning a mutable reference.
    pub fn find_window_mut(&mut self, window_id: u64) -> Option<&mut Window> {
        self.all_windows.iter_mut().filter_map(|w| w.as_mut()).find(|w| w.id == window_id)
    }

    /// Helper to find a window in the global list by ID, returning an immutable reference.
    pub fn find_window(&self, window_id: u64) -> Option<&Window> {
        self.all_windows.iter().filter_map(|w| w.as_ref()).find(|w| w.id == window_id)
    }

    /// Finds the topmost window at the given coordinates (x, y), considering Z-order.
    pub fn get_window_at_coords(&self, x: u32, y: u32) -> Option<&Window> {
        // Iterate through windows in reverse Z-order (topmost first)
        for i in (0..self.global_z_order.num_layers).rev() {
            let window_id = self.global_z_order.z_order[i];
            if let Some(window) = self.find_window(window_id) {
                // Check if the coordinates fall within the window's bounds
                if x >= window.x && x < window.x + window.width &&
                   y >= window.y && y < window.y + window.height {
                    return Some(window);
                }
            }
        }
        None
    }

    /// Sets the tag mask for a specified window.
    pub fn set_window_tags(&mut self, window_id: u64, tag_mask: u64) -> bool {
        if let Some(window) = self.find_window_mut(window_id) {
            window.tag_mask = tag_mask;
            true
        } else {
            false
        }
    }

    /// Gets the tag mask for a specified window.
    pub fn get_window_tags(&self, window_id: u64) -> u64 {
        self.find_window(window_id).map_or(0, |w| w.tag_mask)
    }

    /// Sets the current view's tag mask. Only windows with overlapping tags will be visible.
    pub fn set_view_tags(&mut self, tag_mask: u64) {
        self.current_tag_view_mask = tag_mask;
    }

    /// Gets the current view's tag mask.
    pub fn get_view_tags(&self) -> u64 {
        self.current_tag_view_mask
    }

    /// Returns the ID of the currently focused window.
    pub fn get_focused_window_id(&self) -> Option<u64> {
        if self.global_z_order.num_layers > 0 {
            let focused_id = self.global_z_order.z_order[0];
            if focused_id != 0 {
                return Some(focused_id);
            }
        }
        None
    }

    pub fn apply_animations(&mut self, _last_frame_delta: f32) {
        let step = 20; // Pixels per frame
        for window_opt in self.all_windows.iter_mut().filter_map(|w_opt| w_opt.as_mut()) {
            if window_opt.is_animating {
                let mut finished = true;

                // Move X
                if window_opt.x < window_opt.target_x {
                    window_opt.x = (window_opt.x + step).min(window_opt.target_x);
                    finished = false;
                } else if window_opt.x > window_opt.target_x {
                    window_opt.x = (window_opt.x.saturating_sub(step)).max(window_opt.target_x);
                    finished = false;
                }

                // Move Y
                if window_opt.y < window_opt.target_y {
                    window_opt.y = (window_opt.y + step).min(window_opt.target_y);
                    finished = false;
                } else if window_opt.y > window_opt.target_y {
                    window_opt.y = (window_opt.y.saturating_sub(step)).max(window_opt.target_y);
                    finished = false;
                }

                // Resize Width
                if window_opt.width < window_opt.target_width {
                    window_opt.width = (window_opt.width + step).min(window_opt.target_width);
                    finished = false;
                } else if window_opt.width > window_opt.target_width {
                    window_opt.width = (window_opt.width.saturating_sub(step)).max(window_opt.target_width);
                    finished = false;
                }

                // Resize Height
                if window_opt.height < window_opt.target_height {
                    window_opt.height = (window_opt.height + step).min(window_opt.target_height);
                    finished = false;
                } else if window_opt.height > window_opt.target_height {
                    window_opt.height = (window_opt.height.saturating_sub(step)).max(window_opt.target_height);
                    finished = false;
                }

                if finished {
                    window_opt.is_animating = false;
                }
            }
        }
    }

    /// Handles mouse events, including focus setting and window z-order manipulation.
    pub fn handle_mouse_event(&mut self, x: u32, y: u32, code: u16, value: i32) {
        // Update cursor position regardless of button state
        self.cursor_x = x;
        self.cursor_y = y;

        // Handle mouse button presses for focus
        if code == BTN_LEFT && value == 1 { // Left button pressed
            if let Some(window) = self.get_window_at_coords(x, y) {
                let window_id = window.id;
                
                // Set this window as the focused window
                self.focused_window_id = Some(window_id);

                // Move the focused window to the top of the Z-order
                if let Some(index_to_move) = self.global_z_order.z_order.iter().position(|&id| id == window_id) {
                    // If the window is already at the top, do nothing
                    if index_to_move > 0 {
                        // Shift elements down to make space at the top
                        for i in index_to_move..self.global_z_order.num_layers -1 {
                            self.global_z_order.z_order[i] = self.global_z_order.z_order[i+1];
                        }
                        // Place the window_id at the top
                        self.global_z_order.z_order[0] = window_id;
                    }
                } else {
                    // Window not in z_order, add it to the top if there's space
                    if self.global_z_order.num_layers < MAX_WINDOWS {
                        // Shift existing elements down if necessary
                        for i in (1..self.global_z_order.num_layers).rev() {
                             self.global_z_order.z_order[i] = self.global_z_order.z_order[i-1];
                        }
                        self.global_z_order.z_order[0] = window_id;
                        self.global_z_order.num_layers += 1;
                    }
                    // If no space, it won't be added to z_order, but still focused.
                }
            } else {
                // Clicked outside any window, clear focus
                self.focused_window_id = None;
            }
        }
    }

    /// Handles keyboard events, routing them to the focused window if one exists.
    pub fn handle_keyboard_event(&mut self, code: u16, value: i32, modifiers: u16) {
        // Route keystroke strictly to the focused window's Protection Domain
        if let Some(focused_id) = self.focused_window_id {
            if let Some(window) = self.find_window_mut(focused_id) {
                // Only send events if the window is not minimized or in a state that shouldn't receive input.
                if window.state == WindowState::Tiled || window.state == WindowState::Floating || window.state == WindowState::Maximized {
                    // Prepare the KeyEvent message for PDX
                    let key_event_msg = sex_pdx::MessageType::KeyEvent {
                        code,
                        value,
                        modifiers,
                    };

                    // Send the event via PDX call to the window's PD
                    // Using a placeholder syscall ID 0x0E for PDX_SEX_KEY_EVENT
                    let _ = unsafe {
                        pdx_call(
                            PDX_SEND_MESSAGE, // Assuming PDX_SEND_MESSAGE syscall is available
                            window.pd_id, // Target PD
                            key_event_msg.into(), // Message to send
                            0, // arg2
                            0, // arg3
                        )
                    };
                }
            }
        } else {
            // If no window is focused, handle global hotkeys or compositor shortcuts here.
            // For now, do nothing or log.
        }
    }

