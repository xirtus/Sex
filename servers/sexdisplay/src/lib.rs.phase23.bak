    /// Applies the current tiling layout to all visible windows.
    pub fn apply_tiling(&mut self) {
        // These are global desktop dimensions, not per output
        let global_fb_width = self.global_fb_width;
        let global_fb_height = self.global_fb_height;
        let gaps = self.tiling_state.gaps;

        let mut visible_windows: Vec<&mut Window> = self.all_windows.iter_mut()
            .filter_map(|w_opt| w_opt.as_mut())
            .filter(|w| (w.tag_mask & self.current_tag_view_mask) != 0) // Filter by current view mask
            .collect();
        
        let num_visible = visible_windows.len();
        if num_visible == 0 { return; } // No visible windows to tile

        match self.tiling_state.current_layout {
            TilingLayout::MasterStack => {
                let master_count = self.tiling_state.master_count;
                let master_ratio = self.tiling_state.master_ratio;

                let master_area_width = (global_fb_width as f32 * master_ratio) as u32;
                let tiled_area_x = gaps;
                let tiled_area_y = gaps;
                let tiled_area_width = global_fb_width - gaps * 2;
                let tiled_area_height = global_fb_height - gaps * 2;

                let num_master_windows = num_visible.min(master_count);
                let num_stack_windows = num_visible.saturating_sub(num_master_windows);

                let master_width = if num_stack_windows > 0 { master_area_width } else { tiled_area_width };
                let stack_width = tiled_area_width - master_width - if num_master_windows > 0 && num_stack_windows > 0 { gaps } else { 0 };

                let master_window_height = if num_master_windows > 0 { (tiled_area_height - gaps * (num_master_windows as u32 - 1)) / num_master_windows as u32 } else { 0 };
                let mut current_y = tiled_area_y;
                for i in 0..num_master_windows {
                    let window_ref = &mut visible_windows[i];
                    window_ref.target_x = tiled_area_x;
                    window_ref.target_y = current_y;
                    window_ref.target_width = master_width;
                    window_ref.target_height = master_window_height;
                    current_y += master_window_height + gaps;
                }

                let stack_window_height = if num_stack_windows > 0 { (tiled_area_height - gaps * (num_stack_windows as u32 - 1)) / num_stack_windows as u32 } else { 0 };
                let mut current_y = tiled_area_y;
                for i in 0..num_stack_windows {
                    let window_ref = &mut visible_windows[num_master_windows + i];
                    window_ref.target_x = tiled_area_x + master_width + gaps;
                    window_ref.target_y = current_y;
                    window_ref.target_width = stack_width;
                    window_ref.target_height = stack_window_height;
                    current_y += stack_window_height + gaps;
                }
            },
            TilingLayout::VerticalStack => {
                if num_visible == 0 { return; }

                let window_height = (global_fb_height - gaps * (num_visible as u32 + 1)) / num_visible as u32;
                let mut current_y = gaps;
                for i in 0..num_visible {
                    let window_ref = &mut visible_windows[i];
                    window_ref.target_x = gaps;
                    window_ref.target_y = current_y;
                    window_ref.target_width = global_fb_width - gaps * 2;
                    window_ref.target_height = window_height;
                    current_y += window_height + gaps;
                }
            },
            TilingLayout::HorizontalStack => {
                if num_visible == 0 { return; }

                let window_width = (global_fb_width - gaps * (num_visible as u32 + 1)) / num_visible as u32;
                let mut current_x = gaps;
                for i in 0..num_visible {
                    let window_ref = &mut visible_windows[i];
                    window_ref.target_x = current_x;
                    window_ref.target_y = gaps;
                    window_ref.target_width = window_width;
                    window_ref.target_height = global_fb_height - gaps * 2;
                    current_x += window_width + gaps;
                }
            },
            TilingLayout::Floating => {
                // In floating layout, windows retain their current positions and sizes.
                // Their target_x/y/width/height are already set from previous operations
                // or are explicitly set by PDX_MOVE_WINDOW/PDX_RESIZE_WINDOW.
                // So, no changes are needed here, as the animation system will handle
                // moving them to their targets if they are animating.
            }
        }
    }

    /// Executes a single render command onto the internal framebuffer.
    fn execute_render_command(framebuffer: &mut WindowBuffer, command: &RenderCommand) {
        match command {
            RenderCommand::Clear(color) => {
                unsafe { framebuffer.clear(*color) };
            }
            RenderCommand::DrawRect(rect, color) => {
                unsafe { framebuffer.draw_rect(*rect, *color) };
            }
            RenderCommand::DrawWindow(window_id, rect, pfn_base, original_window) => {
                if *pfn_base == 0 {
                    // This window doesn't have a valid buffer, perhaps draw a placeholder
                    unsafe { framebuffer.draw_rect(*rect, 0xFF0000FF) }; // Magenta placeholder
                    return;
                }

                // Map the window's PFN to get its virtual address
                let window_buffer_vaddr = match unsafe { pdx_map_memory(PDX_MAP_MEMORY, *pfn_base, (rect.w * rect.h * 4) as u64) } {
                    Ok(vaddr) => vaddr,
                    Err(_) => {
                        // Handle error, maybe draw a red placeholder
                        unsafe { framebuffer.draw_rect(*rect, 0xFFFF0000) }; // Red placeholder
                        return;
                    }
                };

                let mut window_buffer = unsafe { WindowBuffer::new(window_buffer_vaddr, rect.w, rect.h, rect.w) }; // Assuming stride == width for simplicity

                // Copy contents from window_buffer to internal_framebuffer with alpha blending and optional blur
                let alpha = original_window.alpha as u32; // 0-255
                let blur_strength = original_window.blur_strength as u32;

                if alpha == 0 { // Fully transparent, do nothing
                    return;
                }

                for y_offset in 0..rect.h {
                    for x_offset in 0..rect.w {
                        let target_x = rect.x as u32 + x_offset;
                        let target_y = rect.y as u32 + y_offset;

                        let src_pixel = unsafe { window_buffer.read_pixel_safe(x_offset, y_offset) };
                        let mut dst_pixel = unsafe { framebuffer.read_pixel_safe(target_x, target_y) };

                        // Apply blur to the destination pixel before blending if blur_strength > 0
                        if blur_strength > 0 {
                            let mut r_sum = 0;
                            let mut g_sum = 0;
                            let mut b_sum = 0;
                            let mut count = 0;

                            for ky in target_y.saturating_sub(blur_strength)..=(target_y + blur_strength).min(framebuffer.height - 1) { // Use framebuffer.height
                                for kx in target_x.saturating_sub(blur_strength)..=(target_x + blur_strength).min(framebuffer.width - 1) { // Use framebuffer.width
                                    let px = unsafe { framebuffer.read_pixel_safe(kx, ky) };
                                    r_sum += (px >> 16) & 0xFF;
                                    g_sum += (px >> 8) & 0xFF;
                                    b_sum += px & 0xFF;
                                    count += 1;
                                }
                            }
                            if count > 0 {
                                dst_pixel = ((r_sum / count) << 16) | ((g_sum / count) << 8) | (b_sum / count);
                            }
                        }

                        if alpha == 255 { // Fully opaque, no blending needed
                            unsafe { framebuffer.draw_pixel_safe(target_x, target_y, src_pixel) };
                        } else { // Perform alpha blending
                            let inv_alpha = 255 - alpha;
                            let blended_pixel = {
                                let src_r = (src_pixel >> 16) & 0xFF;
                                let src_g = (src_pixel >> 8) & 0xFF;
                                let src_b = src_pixel & 0xFF;

                                let dst_r = (dst_pixel >> 16) & 0xFF;
                                let dst_g = (dst_pixel >> 8) & 0xFF;
                                let dst_b = dst_pixel & 0xFF;

                                let out_r = ((src_r * alpha + dst_r * inv_alpha) / 255) & 0xFF;
                                let out_g = ((src_g * alpha + dst_g * inv_alpha) / 255) & 0xFF;
                                let out_b = ((src_b * alpha + dst_b * inv_alpha) / 255) & 0xFF;

                                (out_r << 16) | (out_g << 8) | out_b
                            };
                            unsafe { framebuffer.draw_pixel_safe(target_x, target_y, blended_pixel) };
                        }
                    }
                }

            }
            RenderCommand::DrawBitmap(target_rect, bitmap_data, bitmap_width, bitmap_height, color) => {
                let start_x = target_rect.x.max(0) as u32;
                let start_y = target_rect.y.max(0) as u32;

                for y_offset in 0..*bitmap_height {
                    for x_offset in 0..*bitmap_width {
                        let byte_index = y_offset as usize * (*bitmap_width as usize / 8) + (x_offset as usize / 8);
                        let bit_index = 7 - (x_offset % 8);

                        if byte_index < bitmap_data.len() {
                            if (bitmap_data[byte_index] >> bit_index) & 1 == 1 {
                                unsafe {
                                    framebuffer.draw_pixel_safe(
                                        start_x + x_offset,
                                        start_y + y_offset,
                                        *color,
                                    )
                                };
                            }
                        }
                    }
                }
            }
        }
    }

    /// Evaluates the current UI state and renders a frame to the internal framebuffer.
    pub unsafe fn evaluate_and_render_frame(&mut self) {
        self.apply_animations(0.0); // Apply animations to window positions.
        self.apply_tiling(); // Apply tiling based on the current layout (updates target_x/y/width/height)

        for (output_idx, output) in self.outputs.iter().enumerate() {
            let current_framebuffer = &mut self.internal_framebuffers[output_idx];
            let current_pfn_base = self.internal_framebuffer_pfn_bases[output_idx];

            // 1. Build ephemeral UiStateGraph (for this specific output)
            let mut all_windows_vec: Vec<&Window> = self.all_windows.iter().filter_map(|w_opt| w_opt.as_ref()).collect();

            // Login screen logic: if active, only render login manager's windows
            if self.in_login_screen {
                if let Some(login_pd_id) = self.login_manager_pd_id {
                    all_windows_vec.retain(|w| w.pd_id == login_pd_id);
                } else {
                    // No login manager registered, render nothing or a blank screen
                    all_windows_vec.clear();
                }
            }

            // Filter windows visible on this output
            let visible_on_output: Vec<&Window> = all_windows_vec.iter()
                .filter(|w| {
                    (w.tag_mask & self.current_tag_view_mask) != 0 && // Visible by tag mask
                    (w.x as i32) < (output.x + output.width) as i32 && // Window starts before output ends
                    (w.x as i32 + w.width as i32) > output.x as i32 &&     // Window ends after output starts
                    (w.y as i32) < (output.y + output.height) as i32 && // Window starts before output ends
                    (w.y as i32 + w.height as i32) > output.y as i32       // Window ends after output starts
                })
                .map(|&w| w)
                .collect();

            // Adjust window coordinates to be relative to the output for layout and rendering
            let windows_relative_to_output: Vec<Window> = visible_on_output.iter().map(|&w| {
                let mut new_w = *w;
                new_w.x = new_w.x.saturating_sub(output.x);
                new_w.y = new_w.y.saturating_sub(output.y);
                new_w
            }).collect();

            let visible_refs: Vec<&Window> = windows_relative_to_output.iter().collect();
            
            let ui_graph = UiStateGraph {
                windows: &windows_relative_to_output, // Use relative windows
                outputs: core::slice::from_ref(output), // Pass the current output
                active_tags: self.current_tag_view_mask,
                focus_id: None, // Will implement focus later
                render_flags: RenderState::default(), // Will implement global render flags later
            };

            // 2. Projection Pipeline
            // layout_result will contain coordinates relative to the output
            let layout_result = compute_layout(&visible_refs, output, &self.tiling_state);

            let animated_layout = AnimatedLayout { window_layouts: layout_result.window_layouts }; // Pass through layout_result

            // Prepare all_windows_map for render_decisions (using original global coords)
            let all_windows_map: Vec<(u64, &Window)> = all_windows_vec.iter().map(|w| (w.id, *w)).collect();

            // render_decisions needs output state for dimensions
            let render_commands = render_decisions(&animated_layout, output, all_windows_map.as_slice());

            // 3. Execute RenderCommands on current output's internal_framebuffer
            for command in render_commands.commands {
                Self::execute_render_command(current_framebuffer, &command);
            }

            // 4. Render Notifications
            let current_time_ms = 0; // Placeholder for actual time syscall

            // Filter out expired notifications
            self.active_notifications.retain(|n| n.start_time_ms + n.display_duration_ms > current_time_ms);

            let mut notification_y_offset = output.height - 200; // Start notifications from bottom-right

            for notification in &self.active_notifications {
                let notification_height = 100; // Fixed height for notifications
                let notification_width = 300; // Fixed width for notifications
                let notification_x = output.width - notification_width - 10;
                let notification_y = notification_y_offset;

                // Draw background
                Self::execute_render_command(current_framebuffer, &RenderCommand::DrawRect(
                    Rect { x: notification_x as i32, y: notification_y as i32, w: notification_width, h: notification_height },
                    0xAA333333 // Dark grey, semi-transparent
                ));

                // Draw icon if present
                if notification.icon_pfn != 0 {
                    // For now, draw a placeholder rectangle
                    Self::execute_render_command(current_framebuffer, &RenderCommand::DrawRect(
                        Rect { x: (notification_x + 10) as i32, y: (notification_y + 10) as i32, w: 32, h: 32 },
                        0xFF00FF00 // Green placeholder for icon
                    ));
                }

                // Draw title (placeholder)
                Self::execute_render_command(current_framebuffer, &RenderCommand::DrawRect(
                    Rect { x: (notification_x + 50) as i32, y: (notification_y + 10) as i32, w: 200, h: 20 },
                    0xFFFFFFFF // White placeholder for title
                ));

                // Draw message (placeholder)
                Self::execute_render_command(current_framebuffer, &RenderCommand::DrawRect(
                    Rect { x: (notification_x + 50) as i32, y: (notification_y + 40) as i32, w: 200, h: 40 },
                    0xFFCCCCCC // Light grey placeholder for message
                ));

                notification_y_offset -= (notification_height + 10); // Stack notifications
            }
            // 4. Commit this output's framebuffer to the actual display hardware
            // This needs to be done in main.rs loop
        }
    }

    /// Handles PDX syscalls directed at the SexCompositor.
    /// This function is called by the kernel's syscall dispatcher.
    /// Arguments:
    /// - syscall_id: The specific PDX syscall identifier (e.g., PDX_COMPOSITOR_COMMIT, PDX_SEX_WINDOW_CREATE).
    /// - arg1: First argument for the syscall function (e.g., PFN list pointer, or window creation params pointer).
    /// - arg2: Second argument for the syscall function (e.g., PFN list length).
    /// - arg3: Third argument for the syscall function (e.g., other parameters).
    /// Returns: Result of the syscall (e.g., window ID, success/error code).
    pub unsafe fn handle_pdx_call(&mut self, caller_pd: u32, syscall_id: u64, arg1: u64, arg2: u64, arg3: u64) -> u64 {
        match syscall_id {
            PDX_COMPOSITOR_COMMIT => {
                let pfn_list_ptr = arg1 as *const u64;
                let num_pages = arg2 as usize;
                let pfn_list = core::slice::from_raw_parts(pfn_list_ptr, num_pages);

                let commit_args_for_syscall = [
                    pfn_list.as_ptr() as u64,
                    pfn_list.len() as u64,
                    self.outputs[0].width as u64, // Assume commit to first output for now
                    self.outputs[0].height as u64, // Assume commit to first output for now
                    self.outputs[0].width as u64, // Assume stride = width
                ];

                let ret: i64;
                core::arch::asm!(
                    "syscall",
                    in("rax") 0u64,
                    in("rdi") PDX_COMPOSITOR_COMMIT,
                    in("rsi") commit_args_for_syscall.as_ptr() as u64,
                    lateout("rax") ret,
                    options(nostack, preserves_flags)
                );

                if ret == 0 {
                    if !pfn_list.is_empty() {
                        self.current_scanout_pfn_base = pfn_list[0];
                    }
                    return 0; // Success code
                } else {
                    return 1; // Error code
                }
            }
            PDX_SEX_WINDOW_CREATE => {
                let params_ptr = arg1 as *const SexWindowCreateParams;
                let params = match core::ptr::read_volatile(params_ptr) {
                    val => val,
                };

                if params.width == 0 || params.height == 0 || params.pfn_base == 0 {
                    return 0; // Invalid parameters, return 0 for failure ID
                }

                let new_window = Window {
                    id: self.next_window_id,
                    x: params.x,
                    y: params.y,
                    width: params.width,
                    height: params.height,
                    pfn_base: params.pfn_base,
                    state: WindowState::Tiled, // Default state for tiling
                    pd_id: caller_pd, // Store the PD ID of the caller
                    corner_radius: 0, // Default: no rounded corners
                    blur_strength: 0, // Default: no blur
                    is_animating: false, // Default: not animating
                    border_color: 0, // Default: no border
                    border_thickness: 0, // Default: no border
                    tag_mask: 1 << 0, // Initial tag for the window (tag 0)
                    render_state: RenderState::default(), // Default render state
                    target_x: params.x,
                    target_y: params.y,
                    target_width: params.width,
                    target_height: params.height,
                };
                
                let window_id = self.next_window_id;
                self.next_window_id += 1;

                let mut new_window_slot = None;
                for i in 0..MAX_WINDOWS { // Use MAX_WINDOWS for global list
                    if self.all_windows[i].is_none() {
                        new_window_slot = Some(i);
                        break;
                    }
                }

                let window_index = match new_window_slot {
                    Some(index) => index,
                    None => return 0, // No available window slots, return 0 for failure ID
                };

                self.all_windows[window_index] = Some(new_window);
                window_id
            }
            PDX_SET_WINDOW_DECORATIONS => {
                let params_ptr = arg1 as *const SexWindowDecorationsParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.border_color = params.border_color;
                    window.border_thickness = params.border_thickness;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_SET_WINDOW_ROUNDNESS => {
                let params_ptr = arg1 as *const SexSetWindowRoundnessParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.render_state.corner_radius = params.radius;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_SET_WINDOW_BLUR => {
                let params_ptr = arg1 as *const SexSetWindowBlurParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.render_state.blur_strength = params.strength;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_SET_WINDOW_ANIMATION => {
                let params_ptr = arg1 as *const SexSetWindowAnimationParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.is_animating = params.is_animating;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_GET_DISPLAY_INFO => {
                // Return width and height packed into a u64
                ((self.global_fb_width as u64) << 32) | (self.global_fb_height as u64)
            }
            PDX_FOCUS_WINDOW => {
                let window_id = arg1;
                if self.find_window_mut(window_id).is_some() {
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_MINIMIZE_WINDOW => {
                let window_id = arg1;
                if let Some(window) = self.find_window_mut(window_id) {
                    window.state = WindowState::Minimized;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_MAXIMIZE_WINDOW => {
                let window_id = arg1;
                let gaps = self.tiling_state.gaps;
                let fb_width = self.global_fb_width;
                let fb_height = self.global_fb_height;
                if let Some(window) = self.find_window_mut(window_id) {
                    window.state = WindowState::Maximized;
                    window.target_x = gaps;
                    window.target_y = gaps;
                    window.target_width = fb_width - gaps * 2;
                    window.target_height = fb_height - gaps * 2;
                    window.is_animating = true;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_CLOSE_WINDOW => {
                let window_id = arg1;
                let mut found_index = None;
                for i in 0..MAX_WINDOWS {
                    if let Some(window) = self.all_windows[i] {
                        if window.id == window_id {
                            found_index = Some(i);
                            break;
                        }
                    }
                }

                if let Some(index) = found_index {
                    self.all_windows[index] = None;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_MOVE_WINDOW => {
                let params_ptr = arg1 as *const SexWindowMoveParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.target_x = params.new_x;
                    window.target_y = params.new_y;
                    window.is_animating = true;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_RESIZE_WINDOW => {
                let params_ptr = arg1 as *const SexWindowResizeParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.target_width = params.new_width;
                    window.target_height = params.new_height;
                    window.is_animating = true;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_SET_WINDOW_TAGS => {
                let params_ptr = arg1 as *const SexSetWindowTagsParams;
                let params = core::ptr::read_volatile(params_ptr);
                if self.set_window_tags(params.window_id, params.tag_mask) {
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_GET_WINDOW_TAGS => {
                let window_id = arg1;
                self.get_window_tags(window_id) // Returns tag_mask or 0 if not found
            }
            PDX_SET_VIEW_TAGS => {
                let tag_mask = arg1;
                self.set_view_tags(tag_mask);
                0 // Success
            }
            PDX_GET_VIEW_TAGS => {
                self.get_view_tags() // Returns current_tag_view_mask
            }
            PDX_SWITCH_VIEW => {
                let view_index = arg1 as usize;
                if view_index < self.views.len() {
                    self.current_view_index = view_index;
                    self.current_tag_view_mask = self.views[view_index];
                    0 // Success
                } else {
                    1 // Error: Invalid view index
                }
            }
            PDX_GET_ALL_VIEWS => {
                let pfn_list_ptr = arg1 as *mut u64; // Pointer to caller's buffer
                let num_views_to_copy = arg2 as usize;

                if pfn_list_ptr.is_null() || num_views_to_copy == 0 {
                    return u64::MAX; // Error: Invalid arguments
                }

                let mut copied_count = 0;
                for (i, &view_tag_mask) in self.views.iter().take(num_views_to_copy).enumerate() {
                    unsafe {
                        *pfn_list_ptr.add(i) = view_tag_mask;
                    }
                    copied_count += 1;
                }
                copied_count as u64 // Return number of views copied
            }
            PDX_REGISTER_HOTKEY => {
                let ev_type = arg1 as u16;
                let code = arg2 as u16;
                let value = arg3 as i32;
                let modifiers = 0; // arg4 not provided in current signature

                let hotkey = Hotkey {
                    ev_type,
                    code,
                    value,
                    modifiers,
                    pd_id: caller_pd,
                };
                self.registered_hotkeys.push(hotkey);
                0 // Success
            }
            PDX_SEND_NOTIFICATION => {
                let params_ptr = arg1 as *const SexNotificationParams;
                let params = core::ptr::read_volatile(params_ptr);

                // Copy title from user memory
                let mut title_vec = Vec::with_capacity(params.title_len as usize);
                unsafe {
                    core::ptr::copy_nonoverlapping(
                        params.title_ptr as *const u8,
                        title_vec.as_mut_ptr(),
                        params.title_len as usize,
                    );
                    title_vec.set_len(params.title_len as usize);
                }

                // Copy message from user memory
                let mut message_vec = Vec::with_capacity(params.message_len as usize);
                unsafe {
                    core::ptr::copy_nonoverlapping(
                        params.message_ptr as *const u8,
                        message_vec.as_mut_ptr(),
                        params.message_len as usize,
                    );
                    message_vec.set_len(params.message_len as usize);
                }

                let notification = Notification {
                    id: self.next_notification_id, // Need to add next_notification_id
                    title: title_vec,
                    message: message_vec,
                    icon_pfn: params.icon_pfn,
                    start_time_ms: 0, // Placeholder, need a timer syscall
                    display_duration_ms: params.display_duration_ms,
                };
                self.active_notifications.push(notification);
                self.next_notification_id += 1; // Increment notification ID
                0 // Success
            }
            PDX_SHOW_LOGIN_SCREEN => {
                self.in_login_screen = true;
                self.login_manager_pd_id = Some(caller_pd);
                // In evaluate_and_render_frame, we will check self.in_login_screen
                // and only render the login manager's windows.
                0 // Success
            }
            PDX_HIDE_LOGIN_SCREEN => {
                if self.login_manager_pd_id == Some(caller_pd) {
                    self.in_login_screen = false;
                    self.login_manager_pd_id = None;
                    // In evaluate_and_render_frame, normal windows will be rendered again.
                    0 // Success
                } else {
                    1 // Error: Only the registered login manager can hide the login screen
                }
            }
            PDX_SWITCH_USER_SESSION => {
                // For simplicity, just reset current_tag_view_mask to the first view
                // In a real system, this would involve loading/saving compositor state per user.
                // For now, it clears the current view.
                self.current_tag_view_mask = self.views[0];
                self.current_view_index = 0;
                // Also clear all current windows, as they belong to the old session
                self.all_windows.iter_mut().for_each(|w| *w = None);
                self.global_z_order.num_layers = 0; // Clear Z-order
                0 // Success
            }
            PDX_GET_UI_TREE => {
                let buffer_ptr = arg1 as *mut u8;
                let buffer_len = arg2 as usize;

                if buffer_ptr.is_null() || buffer_len == 0 {
                    return u64::MAX; // Error: Invalid arguments
                }

                let mut copied_bytes = 0;
                for window_opt in self.all_windows.iter().filter_map(|w| w.as_ref()) {
                    let window_size = core::mem::size_of::<Window>();
                    if copied_bytes + window_size <= buffer_len {
                        unsafe {
                            core::ptr::copy_nonoverlapping(
                                window_opt as *const Window as *const u8,
                                buffer_ptr.add(copied_bytes),
                                window_size,
                            );
                        }
                        copied_bytes += window_size;
                    } else {
                        break; // Buffer full
                    }
                }
                copied_bytes as u64 // Return number of bytes copied
            }
            PDX_SET_WINDOW_ROUNDNESS => {
                let params_ptr = arg1 as *const SexSetWindowRoundnessParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.render_state.corner_radius = params.radius;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_SET_WINDOW_BLUR => {
                let params_ptr = arg1 as *const SexSetWindowBlurParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.render_state.blur_strength = params.strength;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_SET_WINDOW_ANIMATION => {
                let params_ptr = arg1 as *const SexSetWindowAnimationParams;
                let params = core::ptr::read_volatile(params_ptr);
                if let Some(window) = self.find_window_mut(params.window_id) {
                    window.is_animating = params.is_animating;
                    0 // Success
                } else {
                    1 // Error: Window not found
                }
            }
            PDX_WINDOW_COMMIT_FRAME => {
                let window_id = arg1;
                let pfn_list_ptr = arg2 as *const u64;
                let num_pages = arg3 as usize;

                if pfn_list_ptr.is_null() || num_pages == 0 {
                    return 1; // Error: Invalid PFN list
                }

                let pfn_list = core::slice::from_raw_parts(pfn_list_ptr, num_pages);

                if let Some(window) = self.find_window_mut(window_id) {
                    window.pfn_base = pfn_list[0];
                    0
                } else {
                    1
                }
            }

            PDX_GET_TIME => {
                // Read TSC; divide by nominal ~1 GHz to get rough milliseconds.
                let low: u32;
                let high: u32;
                unsafe {
                    core::arch::asm!("rdtsc", out("eax") low, out("edx") high, options(nostack, nomem));
                }
                let tsc = ((high as u64) << 32) | (low as u64);
                let ms = tsc / 1_000_000;
                let secs = ms / 1000;
                (secs << 20) | (ms & 0xFFFFF)
            }

            PDX_GET_CPU_USAGE => {
                // No hardware perf counters wired yet — return a flat mock.
                // toys widget will show this as a baseline until the scheduler
                // exposes per-core utilisation via a shared page.
                1500u64 // 15.00 %
            }

            PDX_GET_MEM_USAGE => {
                // Kernel physical allocator stats not yet exposed over PDX.
                // Return a plausible mock: 256 MB used / 2 GB total.
                let used_kb: u64 = 256 * 1024;
                let total_kb: u64 = 2 * 1024 * 1024;
                (used_kb << 32) | total_kb
            }

            _ => {
                0 // unknown syscall
            }
        }
    }
}