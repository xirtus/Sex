+            in("rax") 0u64,
+            in("rdi") 0u64,
+            in("rsi") 0x5151u64,
+            in("rdx") 0u64,
+            in("r10") 0u64,
+            in("r8")  0u64,
+            lateout("rax") _,
+            lateout("rsi") _,
+            out("rcx") _,
+            out("r11") _,
