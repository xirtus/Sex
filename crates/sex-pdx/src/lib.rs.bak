#![no_std]

pub trait Pdx {
    fn listen(&self) -> crate::MessageType;
    fn reply(&self, msg: crate::MessageType);
    fn yield_proc(&self);
}

#[derive(Debug, Clone, Copy)]
pub struct Rect {
    pub x: i32,
    pub y: i32,
    pub width: i32,
    pub height: i32,
}

// Canonical Phase 25/30 Capability Slots (Intel MPK Locked)
pub const SLOT_STORAGE: u64 = 1;
pub const SLOT_NETWORK: u64 = 2;
pub const SLOT_INPUT:   u64 = 3;
pub const SLOT_AUDIO:   u64 = 4;
pub const SLOT_DISPLAY: u64 = 5;
pub const SLOT_SHELL:   u64 = 6;

// Re-export MessageType from kernel for Userland
pub use crate::ipc::messages::MessageType;
