## Core boot function

```rust id="boot04"
impl BootState {
    pub fn new() -> Self {
        Self { started: vec![] }
    }

    pub fn can_start(&self, node: &BootNode) -> bool {
        node.deps.iter().all(|d| self.started.contains(d))
    }

    pub fn start_node(&mut self, node: &BootNode) {
        self.started.push(node.name);
    }
}
```

