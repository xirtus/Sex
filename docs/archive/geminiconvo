use crate::boot::*;

pub fn execute_boot_dag() {
    let mut state = BootState::new();

    loop {
        let mut progress = false;

        for node in BOOT_DAG.iter() {
            if !state.started.contains(&node.name)
                && state.can_start(node)
            {
                spawn_server(node.name);
                state.start_node(node);
                progress = true;
            }
        }

        if !progress {
            break;
        }
    }
}
