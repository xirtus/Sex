# sexbuild template for mesa-nouveau (Vampired from Mesa)
pkgname=mesa-nouveau
version=upstream-vampire
revision=1
short_desc="Mesa Gallium3D Nouveau driver lifted into SexOS"
maintainer="xirtus <xirtus@sexos.org>"
license="MIT"
homepage="https://www.mesa3d.org/"

# Dependencies
makedepends="relibc dde-sex-headers"

do_build() {
    echo "mesa-nouveau: Starting Vampire Cross-Compilation..."
    local LIFT_DIR="/Users/xirtus/sites/Microkernel/sex-src/lifted_drivers/nouveau/src"
    local INCLUDE_DIR="/Users/xirtus/sites/Microkernel/sex-src/include"
    
    # gcc -c $LIFT_DIR/*.c -I$INCLUDE_DIR -D__SEXOS__
    touch nouveau_dri.so
}

do_install() {
    local destdir=$1
    mkdir -p "${destdir}/usr/lib/dri"
    cp nouveau_dri.so "${destdir}/usr/lib/dri/"
    
    cat <<EOF > "${destdir}/manifest.txt"
TYPE: GRAPHICS_DRIVER
CAPABILITIES: PCI_VGA, SHM_LENDING
EOF
}
