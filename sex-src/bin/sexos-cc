#!/usr/bin/env bash
# sexos-cc: The SexOS C Compiler Wrapper
# Wraps the host compiler to target the Sex Microkernel SASOS environment.

readonly BASE_DIR="/Users/xirtus/sites/microkernel/sex-src"
readonly INCLUDE_DIR="$BASE_DIR/include"
readonly LIB_DIR="$BASE_DIR/lib"

# Default to clang if CC is not set
CC=${CC:-clang}

# Core SexOS compilation flags:
# 1. -nostdinc / -nostdlib: Use our custom headers and runtime.
# 2. -fno-stack-protector: Keep it simple for the initial prototype.
# 3. -static: All binaries are statically linked into the SASOS.
# 4. -mcmodel=large: Required for our 64-bit Global SAS addresses.

FLAGS=(
    "-nostdinc"
    "-I$INCLUDE_DIR"
    "-fno-stack-protector"
    "-mcmodel=large"
    "-static"
    "-D__sexos__"
)

# Run the real compiler
exec $CC "${FLAGS[@]}" "$@"
