#!/usr/bin/env bash
# sexos-cc: The SexOS C Compiler Wrapper
# Wraps the host compiler to target the Sex Microkernel SASOS environment.

readonly BASE_DIR="/Users/xirtus/sites/microkernel/sex-src"
readonly INCLUDE_DIR="$BASE_DIR/include"
readonly RELIBC_INCLUDE="$BASE_DIR/lib/relibc-sexos/include"
readonly LIB_DIR="$BASE_DIR/lib"

# Default to clang if CC is not set
CC=${CC:-clang}

# Core SexOS compilation flags:
FLAGS=(
    "--target=x86_64-unknown-none"
    "-nostdinc"
    "-I$INCLUDE_DIR"
    "-I$RELIBC_INCLUDE"
    "-fno-stack-protector"
    "-mcmodel=large"
    "-static"
    "-D__sexos__"
)

# Run the real compiler
exec $CC "${FLAGS[@]}" "$@"
