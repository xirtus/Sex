[package]
name = "sex-kernel"
version = "0.1.0"
edition = "2021"

[dependencies]
limine = "0.6.3"
x86_64 = { version = "0.15.2", default-features = false, features = ["instructions", "abi_x86_interrupt", "nightly"] }
uart_16550 = { version = "0.3.0", default-features = false }
spinning_top = { version = "0.3.0", default-features = false }
lazy_static = { version = "1.5.0", features = ["spin_no_std"] }
conquer-once = { version = "0.4.0", default-features = false }
linked_list_allocator = { version = "0.10.5", default-features = false, features = ["use_spin"] }
crossbeam-queue = { version = "0.3.8", default-features = false, features = ["alloc"] }
acpi = { version = "6.1.1", default-features = false, features = ["alloc", "aml"] }
aml = { version = "0.16.4", default-features = false }
smoltcp = { version = "0.13.0", default-features = false, features = ["proto-ipv4", "proto-ipv6", "socket-tcp", "socket-udp", "log", "medium-ip", "medium-ethernet"] }
# sha2 = { version = "0.10", default-features = false }
# chacha20poly1305 = { version = "0.10", default-features = false }
# ed25519-dalek = { version = "2.1", default-features = false }
pci_types = "0.10"
nvme-oxide = "0.4"
# rustls = { version = "0.23", default-features = false }
# rustls-rustcrypto = "0.0.2-alpha"
x2apic = "0.5"
# pic8259 = { version = "0.10.1", default-features = false } # Removed for APIC parity

# Explicitly disable default features for transitive deps (prevents build noise)
bitflags = { version = "2.4.0", default-features = false }
radium = { version = "0.7.0", default-features = false }
bit_field = { version = "0.10.3", default-features = false }
volatile = { version = "0.4.6", default-features = false }
scopeguard = { version = "1.2.0", default-features = false }
tap = { version = "1.0.1", default-features = false }
spin = { version = "0.9.8", default-features = false, features = ["mutex", "spin_mutex"] }
raw-cpuid = { version = "11.2.0", default-features = false }
