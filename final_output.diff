+    pub fn setup_msix(&self, vector: u8, target_core: u8) {
+        serial_println!("PCI: Setting up MSI-X for {:02x}:{:02x}.{:x} -> Vector {:#x}", 
+            self.bus, self.dev, self.func, vector);
