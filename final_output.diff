+pub struct Pkru;
+
+impl Pkru {
+    /// Reads the current PKRU register value.
+    #[inline]
+    pub fn read() -> u32 {
+        let pkru: u32;
+        unsafe {
+            asm!(
+                "rdpkru",
+                out("eax") pkru,
+                in("ecx") 0,
+                out("edx") _,
+            );
+        }
+        pkru
+    }
+
+    /// Writes a new value to the PKRU register.
+    #[inline]
+    pub fn write(val: u32) {
+        unsafe {
+            asm!(
+                "wrpkru",
+                in("eax") val,
+                in("ecx") 0,
+                in("edx") 0,
+            );
